  (segment (start -3.0 -13.5) (end -3.0 -12.5) (width 0.5) (layer "B.Cu") (net 3) (uuid "a0000003-0000-0000-0000-000000000002"))

  ;; TEST: one zone
  (zone (net 1) (net_name "GND") (layer "In1.Cu")
    (uuid "a0000004-0000-0000-0000-000000000001")
    (hatch edge 0.5)
