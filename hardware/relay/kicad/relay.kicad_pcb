(kicad_pcb
  (version 20240108)
  (generator "briolette_relay")
  (generator_version "8.0")
  (general
    (thickness 1.6)
    (legacy_teardrops no)
  )
  (paper "A4")
  (title_block
    (title "Briolette Solar Relay")
    (date "2026-03-13")
    (rev "1.0")
    (comment 1 "70x45mm, 4-layer, solar-powered NFC reader")
    (comment 2 "Top: components + solar cell. Bottom: NFC reader antenna")
  )

  ;; 4-Layer Stackup
  (layers
    (0 "F.Cu" signal)
    (1 "In1.Cu" signal "GND")
    (2 "In2.Cu" signal "PWR")
    (31 "B.Cu" signal)
    (32 "B.Adhes" user "B.Adhesive")
    (33 "F.Adhes" user "F.Adhesive")
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user "B.Silkscreen")
    (37 "F.SilkS" user "F.Silkscreen")
    (38 "B.Mask" user "B.Mask")
    (39 "F.Mask" user "F.Mask")
    (40 "Dwgs.User" user "User.Drawings")
    (41 "Cmts.User" user "User.Comments")
    (42 "Eco1.User" user "User.Eco1")
    (43 "Eco2.User" user "User.Eco2")
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
    (46 "B.CrtYd" user "B.Courtyard")
    (47 "F.CrtYd" user "F.Courtyard")
    (48 "B.Fab" user "B.Fabrication")
    (49 "F.Fab" user "F.Fabrication")
  )

  (setup
    (stackup
      (layer "F.Cu" (type "copper") (thickness 0.035))
      (layer "dielectric 1" (type "prepreg") (thickness 0.2) (material "FR4") (epsilon_r 4.5))
      (layer "In1.Cu" (type "copper") (thickness 0.035))
      (layer "dielectric 2" (type "core") (thickness 1.065) (material "FR4") (epsilon_r 4.5))
      (layer "In2.Cu" (type "copper") (thickness 0.035))
      (layer "dielectric 3" (type "prepreg") (thickness 0.2) (material "FR4") (epsilon_r 4.5))
      (layer "B.Cu" (type "copper") (thickness 0.035))
      (copper_finish "HASL with lead")
    )
    (pad_to_mask_clearance 0.05)
    (pcbplotparams
      (outputdirectory "../gerbers/")
    )
  )

  ;; Nets
  (net 0 "")
  (net 1 "GND")
  (net 2 "VCC")
  (net 3 "VSOLAR")
  (net 4 "VSCAP")
  (net 5 "I2C_SDA")
  (net 6 "I2C_SCL")
  (net 7 "NFC_IRQ")
  (net 8 "NFC_VEN")
  (net 9 "BTN1")
  (net 10 "BTN2")
  (net 11 "BTN3")
  (net 12 "BTN4")
  (net 13 "LED_R")
  (net 14 "LED_G")
  (net 15 "LED_B")
  (net 16 "VBUS")
  (net 17 "USB_DP")
  (net 18 "USB_DM")
  (net 19 "NFC_TX1")
  (net 20 "NFC_TX2")
  (net 21 "NFC_RX")
  (net 22 "VBAT_OK")
  (net 23 "LBST")

  ;; ============================================================
  ;; Board outline (70mm x 45mm, rounded corners 2mm radius)
  ;; Origin at board center
  ;; ============================================================
  (gr_line (start -33.0 -22.5) (end 33.0 -22.5)
    (stroke (width 0.1) (type default)) (layer "Edge.Cuts"))
  (gr_line (start 35.0 -20.5) (end 35.0 20.5)
    (stroke (width 0.1) (type default)) (layer "Edge.Cuts"))
  (gr_line (start 33.0 22.5) (end -33.0 22.5)
    (stroke (width 0.1) (type default)) (layer "Edge.Cuts"))
  (gr_line (start -35.0 20.5) (end -35.0 -20.5)
    (stroke (width 0.1) (type default)) (layer "Edge.Cuts"))

  ;; Rounded corners
  (gr_arc (start -33.0 -22.5) (mid -34.414 -21.914) (end -35.0 -20.5)
    (stroke (width 0.1) (type default)) (layer "Edge.Cuts"))
  (gr_arc (start 35.0 -20.5) (mid 34.414 -21.914) (end 33.0 -22.5)
    (stroke (width 0.1) (type default)) (layer "Edge.Cuts"))
  (gr_arc (start 33.0 22.5) (mid 34.414 21.914) (end 35.0 20.5)
    (stroke (width 0.1) (type default)) (layer "Edge.Cuts"))
  (gr_arc (start -35.0 20.5) (mid -34.414 21.914) (end -33.0 22.5)
    (stroke (width 0.1) (type default)) (layer "Edge.Cuts"))

  ;; ============================================================
  ;; Component placement zones (top layer)
  ;; ============================================================

  ;; Solar cell pads (top-left area, 40x30mm)
  (gr_rect (start -32 -20) (end 8 10)
    (stroke (width 0.15) (type dash)) (fill none) (layer "Cmts.User"))
  (gr_text "SOLAR CELL\n40x30mm" (at -12 -5 0) (layer "Cmts.User")
    (effects (font (size 1.5 1.5) (thickness 0.2))))

  ;; NFC reader antenna zone (bottom layer, right half)
  (gr_rect (start -5 -18) (end 32 18)
    (stroke (width 0.15) (type dash)) (fill none) (layer "Cmts.User"))
  (gr_text "NFC READER ANTENNA\n~35x25mm (B.Cu)" (at 13.5 0 0) (layer "Cmts.User")
    (effects (font (size 1.2 1.2) (thickness 0.15))))

  ;; nRF52840: center-left (under solar cell area)
  (footprint "stick-lib:QFN-48-6x6mm"
    (layer "F.Cu")
    (at -20.0 0 0)
    (property "Reference" "U1"
      (at 0 -5.5 0) (layer "F.SilkS")
      (effects (font (size 0.8 0.8) (thickness 0.12))))
    (property "Value" "nRF52840"
      (at 0 5.5 0) (layer "F.Fab")
      (effects (font (size 0.8 0.8) (thickness 0.12))))
  )

  ;; PN7150: center-right (near NFC antenna area)
  (footprint "relay-lib:HVQFN-40-5x5mm"
    (layer "F.Cu")
    (at 10.0 0 0)
    (property "Reference" "U2"
      (at 0 -4.5 0) (layer "F.SilkS")
      (effects (font (size 0.8 0.8) (thickness 0.12))))
    (property "Value" "PN7150"
      (at 0 4.5 0) (layer "F.Fab")
      (effects (font (size 0.8 0.8) (thickness 0.12))))
  )

  ;; BQ25504: upper-left (near solar cell connections)
  (footprint "relay-lib:QFN-20-3.5x3.5mm"
    (layer "F.Cu")
    (at -8.0 -15.0 0)
    (property "Reference" "U3"
      (at 0 -3.5 0) (layer "F.SilkS")
      (effects (font (size 0.6 0.6) (thickness 0.1))))
    (property "Value" "BQ25504"
      (at 0 3.5 0) (layer "F.Fab")
      (effects (font (size 0.6 0.6) (thickness 0.1))))
  )

  ;; LDO: near BQ25504
  (footprint "Package_TO_SOT_SMD:SOT-23-5"
    (layer "F.Cu")
    (at -8.0 -8.0 0)
    (property "Reference" "U4"
      (at 0 -3.0 0) (layer "F.SilkS")
      (effects (font (size 0.6 0.6) (thickness 0.1))))
    (property "Value" "AP2112K-3.3"
      (at 0 3.0 0) (layer "F.Fab")
      (effects (font (size 0.6 0.6) (thickness 0.1))))
  )

  ;; USB-C: bottom edge
  (footprint "stick-lib:USB_C_GCT_USB4135"
    (layer "F.Cu")
    (at 0 20.0 0)
    (property "Reference" "J1"
      (at 0 -7.0 0) (layer "F.SilkS")
      (effects (font (size 0.8 0.8) (thickness 0.12))))
    (property "Value" "USB4135-GF-A"
      (at 0 7.0 0) (layer "F.Fab")
      (effects (font (size 0.8 0.8) (thickness 0.12))))
  )

  ;; 4 Buttons: left side, vertical column
  (footprint "stick-lib:SW_SPST_3x3mm" (layer "F.Cu") (at -30.0 -15.0 0)
    (property "Reference" "SW1" (at 0 -2.5 0) (layer "F.SilkS")
      (effects (font (size 0.6 0.6) (thickness 0.1))))
    (property "Value" "BTN1" (at 0 2.5 0) (layer "F.Fab")
      (effects (font (size 0.6 0.6) (thickness 0.1)))))
  (footprint "stick-lib:SW_SPST_3x3mm" (layer "F.Cu") (at -30.0 -8.0 0)
    (property "Reference" "SW2" (at 0 -2.5 0) (layer "F.SilkS")
      (effects (font (size 0.6 0.6) (thickness 0.1))))
    (property "Value" "BTN2" (at 0 2.5 0) (layer "F.Fab")
      (effects (font (size 0.6 0.6) (thickness 0.1)))))
  (footprint "stick-lib:SW_SPST_3x3mm" (layer "F.Cu") (at -30.0 -1.0 0)
    (property "Reference" "SW3" (at 0 -2.5 0) (layer "F.SilkS")
      (effects (font (size 0.6 0.6) (thickness 0.1))))
    (property "Value" "BTN3" (at 0 2.5 0) (layer "F.Fab")
      (effects (font (size 0.6 0.6) (thickness 0.1)))))
  (footprint "stick-lib:SW_SPST_3x3mm" (layer "F.Cu") (at -30.0 6.0 0)
    (property "Reference" "SW4" (at 0 -2.5 0) (layer "F.SilkS")
      (effects (font (size 0.6 0.6) (thickness 0.1))))
    (property "Value" "BTN4" (at 0 2.5 0) (layer "F.Fab")
      (effects (font (size 0.6 0.6) (thickness 0.1)))))

  ;; 3 LEDs: near buttons
  (footprint "LED_SMD:LED_0402_1005Metric" (layer "F.Cu") (at -30.0 12.0 0)
    (property "Reference" "LED1" (at 0 -1.5 0) (layer "F.SilkS")
      (effects (font (size 0.5 0.5) (thickness 0.08))))
    (property "Value" "RED" (at 0 1.5 0) (layer "F.Fab")
      (effects (font (size 0.5 0.5) (thickness 0.08)))))
  (footprint "LED_SMD:LED_0402_1005Metric" (layer "F.Cu") (at -27.0 12.0 0)
    (property "Reference" "LED2" (at 0 -1.5 0) (layer "F.SilkS")
      (effects (font (size 0.5 0.5) (thickness 0.08))))
    (property "Value" "GREEN" (at 0 1.5 0) (layer "F.Fab")
      (effects (font (size 0.5 0.5) (thickness 0.08)))))
  (footprint "LED_SMD:LED_0402_1005Metric" (layer "F.Cu") (at -24.0 12.0 0)
    (property "Reference" "LED3" (at 0 -1.5 0) (layer "F.SilkS")
      (effects (font (size 0.5 0.5) (thickness 0.08))))
    (property "Value" "BLUE" (at 0 1.5 0) (layer "F.Fab")
      (effects (font (size 0.5 0.5) (thickness 0.08)))))

  ;; ============================================================
  ;; NFC Reader Antenna (bottom copper, 35x25mm, 3 turns)
  ;; Generates 13.56 MHz field to power credsticks
  ;; ============================================================

  ;; Turn 1 (outermost)
  (gr_line (start -3.0 -12.5) (end 30.0 -12.5)
    (stroke (width 0.5) (type default)) (layer "B.Cu") (net 19))
  (gr_line (start 30.0 -12.5) (end 30.0 12.5)
    (stroke (width 0.5) (type default)) (layer "B.Cu") (net 19))
  (gr_line (start 30.0 12.5) (end -3.0 12.5)
    (stroke (width 0.5) (type default)) (layer "B.Cu") (net 19))
  (gr_line (start -3.0 12.5) (end -3.0 -12.5)
    (stroke (width 0.5) (type default)) (layer "B.Cu") (net 19))

  ;; Turn 2
  (gr_line (start -2.0 -11.5) (end 29.0 -11.5)
    (stroke (width 0.5) (type default)) (layer "B.Cu") (net 19))
  (gr_line (start 29.0 -11.5) (end 29.0 11.5)
    (stroke (width 0.5) (type default)) (layer "B.Cu") (net 19))
  (gr_line (start 29.0 11.5) (end -2.0 11.5)
    (stroke (width 0.5) (type default)) (layer "B.Cu") (net 19))
  (gr_line (start -2.0 11.5) (end -2.0 -11.5)
    (stroke (width 0.5) (type default)) (layer "B.Cu") (net 19))

  ;; Turn 3 (innermost)
  (gr_line (start -1.0 -10.5) (end 28.0 -10.5)
    (stroke (width 0.5) (type default)) (layer "B.Cu") (net 20))
  (gr_line (start 28.0 -10.5) (end 28.0 10.5)
    (stroke (width 0.5) (type default)) (layer "B.Cu") (net 20))
  (gr_line (start 28.0 10.5) (end -1.0 10.5)
    (stroke (width 0.5) (type default)) (layer "B.Cu") (net 20))
  (gr_line (start -1.0 10.5) (end -1.0 -10.5)
    (stroke (width 0.5) (type default)) (layer "B.Cu") (net 20))

  ;; NFC antenna vias (connect bottom traces to top-layer PN7150)
  (via (at -3.0 -13.5) (size 0.6) (drill 0.3)
    (layers "F.Cu" "B.Cu") (net 19))
  (via (at -1.0 -11.5) (size 0.6) (drill 0.3)
    (layers "F.Cu" "B.Cu") (net 20))

  ;; ============================================================
  ;; Zones
  ;; ============================================================

  ;; GND plane (In1.Cu)
  (zone (net 1) (net_name "GND") (layer "In1.Cu")
    (uuid "zone-relay-gnd")
    (hatch edge 0.5)
    (connect_pads (clearance 0.3))
    (min_thickness 0.2)
    (fill yes (thermal_gap 0.3) (thermal_bridge_width 0.3))
    (polygon (pts (xy -35 -22.5) (xy 35 -22.5) (xy 35 22.5) (xy -35 22.5))))

  ;; VCC plane (In2.Cu)
  (zone (net 2) (net_name "VCC") (layer "In2.Cu")
    (uuid "zone-relay-vcc")
    (hatch edge 0.5)
    (connect_pads (clearance 0.3))
    (min_thickness 0.2)
    (fill yes (thermal_gap 0.3) (thermal_bridge_width 0.3))
    (polygon (pts (xy -35 -22.5) (xy 35 -22.5) (xy 35 22.5) (xy -35 22.5))))

  ;; Keep-out under NFC reader antenna (inner layers)
  (zone (net 0) (net_name "") (layer "In1.Cu")
    (uuid "zone-relay-keepout-gnd")
    (hatch edge 0.5)
    (connect_pads (clearance 0))
    (min_thickness 0.2)
    (keepout (tracks not_allowed) (vias not_allowed) (pads not_allowed)
      (copperpour not_allowed) (footprints allowed))
    (fill (thermal_gap 0.3) (thermal_bridge_width 0.3))
    (polygon (pts (xy -5 -14) (xy 32 -14) (xy 32 14) (xy -5 14))))

  (zone (net 0) (net_name "") (layer "In2.Cu")
    (uuid "zone-relay-keepout-pwr")
    (hatch edge 0.5)
    (connect_pads (clearance 0))
    (min_thickness 0.2)
    (keepout (tracks not_allowed) (vias not_allowed) (pads not_allowed)
      (copperpour not_allowed) (footprints allowed))
    (fill (thermal_gap 0.3) (thermal_bridge_width 0.3))
    (polygon (pts (xy -5 -14) (xy 32 -14) (xy 32 14) (xy -5 14))))

  ;; ============================================================
  ;; Silkscreen / annotations
  ;; ============================================================
  (gr_text "Briolette Solar Relay" (at 0 -24.0 0) (layer "F.SilkS")
    (effects (font (size 1.5 1.5) (thickness 0.2) bold)))

  (gr_text "TAP HERE" (at 13.5 0 0) (layer "B.SilkS")
    (effects (font (size 2.0 2.0) (thickness 0.3) bold)))

  (gr_text "Layer Stack:\nF.Cu  — Components + solar cell pads\nIn1   — GND (keep-out under antenna)\nIn2   — VCC (keep-out under antenna)\nB.Cu  — NFC reader antenna (3-turn spiral)"
    (at -25.0 -28.0 0) (layer "Cmts.User")
    (effects (font (size 0.8 0.8) (thickness 0.12))))
)
