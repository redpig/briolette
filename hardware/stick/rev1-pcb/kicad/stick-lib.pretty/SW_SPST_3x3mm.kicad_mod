(footprint "SW_SPST_3x3mm"
  (version 20240108)
  (generator "briolette_credstick")
  (generator_version "8.0")
  (layer "F.Cu")
  (descr "3x3mm SMD tactile switch, 4-pin, common SPST momentary push button")
  (tags "tactile switch button 3x3mm SMD SPST")
  (property "Reference" "REF**"
    (at 0 -2.8 0)
    (layer "F.SilkS")
    (effects (font (size 0.8 0.8) (thickness 0.12)))
  )
  (property "Value" "SW_SPST_3x3mm"
    (at 0 2.8 0)
    (layer "F.Fab")
    (effects (font (size 0.8 0.8) (thickness 0.12)))
  )
  (attr smd)

  ;; Courtyard
  (fp_rect
    (start -2.5 -2.2)
    (end 2.5 2.2)
    (stroke (width 0.05) (type default))
    (fill none)
    (layer "F.CrtYd")
  )

  ;; Body outline
  (fp_rect
    (start -1.5 -1.5)
    (end 1.5 1.5)
    (stroke (width 0.1) (type default))
    (fill none)
    (layer "F.Fab")
  )

  ;; Button circle on fab
  (fp_circle
    (center 0 0)
    (end 0.75 0)
    (stroke (width 0.1) (type default))
    (fill none)
    (layer "F.Fab")
  )

  ;; 4 pads (internally shorted: 1-2 are one side, 3-4 are the other)
  (pad "1" smd rect (at -1.8 -0.75) (size 1.0 0.7) (layers "F.Cu" "F.Paste" "F.Mask"))
  (pad "2" smd rect (at 1.8 -0.75) (size 1.0 0.7) (layers "F.Cu" "F.Paste" "F.Mask"))
  (pad "3" smd rect (at -1.8 0.75) (size 1.0 0.7) (layers "F.Cu" "F.Paste" "F.Mask"))
  (pad "4" smd rect (at 1.8 0.75) (size 1.0 0.7) (layers "F.Cu" "F.Paste" "F.Mask"))
)
