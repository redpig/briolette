(footprint "Supercap_Cylindrical_14mm"
  (version 20240108)
  (generator "briolette_credstick")
  (generator_version "8.0")
  (layer "F.Cu")
  (descr "Kyocera AVX SCC 5F 3V cylindrical supercapacitor, 14mm dia x ~20mm tall, radial THT")
  (tags "supercapacitor capacitor AVX SCC SCCR14E505SRB")
  (property "Reference" "REF**"
    (at 0 -9.5 0)
    (layer "F.SilkS")
    (effects (font (size 1 1) (thickness 0.15)))
  )
  (property "Value" "Supercap_Cylindrical_14mm"
    (at 0 9.5 0)
    (layer "F.Fab")
    (effects (font (size 1 1) (thickness 0.15)))
  )
  (attr through_hole)

  ;; Courtyard (slightly larger than body)
  (fp_circle
    (center 0 0)
    (end 8.5 0)
    (stroke (width 0.05) (type default))
    (fill none)
    (layer "F.CrtYd")
  )

  ;; Body outline on fabrication layer
  (fp_circle
    (center 0 0)
    (end 7.0 0)
    (stroke (width 0.1) (type default))
    (fill none)
    (layer "F.Fab")
  )

  ;; Polarity marker (+) on silkscreen
  (fp_line (start -1.5 -8.0) (end 1.5 -8.0)
    (stroke (width 0.2) (type default)) (layer "F.SilkS"))
  (fp_line (start 0 -9.5) (end 0 -6.5)
    (stroke (width 0.2) (type default)) (layer "F.SilkS"))

  ;; Through-hole pads, 2.54mm pitch (standard radial capacitor)
  ;; Positive pad
  (pad "1" thru_hole circle
    (at -2.5 0)
    (size 2.0 2.0)
    (drill 1.0)
    (layers "*.Cu" "*.Mask")
  )
  ;; Negative pad
  (pad "2" thru_hole circle
    (at 2.5 0)
    (size 2.0 2.0)
    (drill 1.0)
    (layers "*.Cu" "*.Mask")
  )
)
