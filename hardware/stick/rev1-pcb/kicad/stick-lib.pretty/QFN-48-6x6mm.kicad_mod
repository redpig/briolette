  (generator_version "8.0")
  (layer "F.Cu")
  (descr "QFN-48 6x6mm 0.4mm pitch, nRF52840-QIAA with exposed pad")
  (tags "QFN QFN-48 nRF52840")
  (property "Reference" "REF**"
    (at 0 -4.5 0)
    (layer "F.SilkS")
    (effects (font (size 1 1) (thickness 0.15)))
