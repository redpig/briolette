        (start -10.16 12.7)
        (end 10.16 -12.7)
        (stroke (width 0.254) (type default))
        (fill (type background))
      )
      ;; ISO 7816 contact C1: VCC
      (pin power_in line (at -12.7 10.16 0) (length 2.54)
        (name "VCC" (effects (font (size 1.27 1.27))))
        (number "C1" (effects (font (size 1.27 1.27))))
      )
      ;; ISO 7816 contact C2: RST
      (pin input line (at 12.7 10.16 180) (length 2.54)
        (name "RST" (effects (font (size 1.27 1.27))))
        (number "C2" (effects (font (size 1.27 1.27))))
      )
      ;; ISO 7816 contact C3: CLK
      (pin input line (at 12.7 5.08 180) (length 2.54)
        (name "CLK" (effects (font (size 1.27 1.27))))
        (number "C3" (effects (font (size 1.27 1.27))))
      )
      ;; ISO 7816 contact C5: GND
      (pin power_in line (at -12.7 -10.16 0) (length 2.54)
        (name "GND" (effects (font (size 1.27 1.27))))
        (number "C5" (effects (font (size 1.27 1.27))))
      )
      ;; ISO 7816 contact C6: VPP (connect to VCC for modern SIM)
      (pin passive line (at -12.7 5.08 0) (length 2.54)
        (name "VPP" (effects (font (size 1.27 1.27))))
        (number "C6" (effects (font (size 1.27 1.27))))
      )
      ;; ISO 7816 contact C7: I/O (half-duplex data)
      (pin bidirectional line (at 12.7 0 180) (length 2.54)
        (name "IO" (effects (font (size 1.27 1.27))))
        (number "C7" (effects (font (size 1.27 1.27))))
      )
      ;; Card detect switch (active low when card inserted)
      (pin input line (at 12.7 -5.08 180) (length 2.54)
        (name "CD" (effects (font (size 1.27 1.27))))
        (number "CD" (effects (font (size 1.27 1.27))))
      )
      ;; Mechanical shell / shield
